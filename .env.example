# Copy to .env and fill with your Supabase project values
# (Settings -> API Keys -> Publishable key; Project URL from the API page)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Root domain client sites are served under (<subdomain>.<this>). Optional —
# falls back to the value in src/config/site.js if unset. See that file for the
# full "how to change your platform domain" steps.
VITE_PLATFORM_DOMAIN=celebrately.us
